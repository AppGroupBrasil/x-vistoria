# ===== X Vistoria — Variáveis de Ambiente =====
# Copie para .env e preencha com valores reais
# NUNCA commitar o .env no Git!

# Banco de dados (obrigatório)
DB_PASSWORD=SenhaForteAqui123

# Redis (obrigatório)
REDIS_PASSWORD=RedisForteAqui456

# JWT — mínimo 32 caracteres (obrigatório)
JWT_SECRET=jwt-secret-muito-longo-e-aleatorio-aqui-minimo-32-chars

# IA (opcional — deixe vazio se não usar)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Email via Google SMTP (obrigatório para recuperação de senha)
# Use uma senha de app do Google, não a senha normal da conta.
GOOGLE_SMTP_USER=seuemail@gmail.com
GOOGLE_SMTP_APP_PASSWORD=senha-app-16-caracteres
MAIL_FROM="X Vistoria <seuemail@gmail.com>"

# Base pública do frontend usada nos links de redefinição.
# Se não informar, usa FRONTEND_URL.
PASSWORD_RESET_URL_BASE=https://xvistoria.com.br

# Hetzner Object Storage (obrigatório)
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_ACCESS_KEY=...
HETZNER_S3_SECRET_KEY=...
HETZNER_S3_BUCKET=xvistoria-fotos

# SMTP de Notificações ao Morador (Resend)
# Domínio precisa ser verificado em https://resend.com/domains
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_xxx_sua_api_key
SMTP_FROM=X Vistoria <notificacoes@xvistoria.com.br>
